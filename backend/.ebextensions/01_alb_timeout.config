###############################################################################
# Bump the Application Load Balancer idle timeout to 30 minutes (1800s).
#
# Default is 60 seconds, which is the exact same class of bug as Render Free's
# 100-second cap: long Whisper transcription requests (10+ min of audio takes
# 60-90s; longer audio + the /generate-note GPT call can take several minutes)
# would be killed mid-flight, leaving the user with a stuck "Processing..." UI.
#
# 1800s gives the worst-case 2-hour recording's final-segment transcribe + GPT
# call ample headroom. The actual Node process still has its own timeouts
# configured in src/index.ts (no socket timeout, 20-min headers timeout).
###############################################################################
option_settings:
  aws:elbv2:loadbalancer:
    IdleTimeout: 1800
