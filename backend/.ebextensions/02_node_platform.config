###############################################################################
# Node platform settings.
#
# - NodeCommand: how Elastic Beanstalk starts the app. We point at the compiled
#   output (npm run build emits dist/index.js).
# - ProxyServer: "none" — let Node handle requests directly via the ALB. The
#   default nginx in front of Node would re-introduce a separate proxy timeout
#   (60s) that we'd then have to also bump. Skipping nginx is simpler and avoids
#   a second timeout layer; the ALB already does TLS termination and routing.
# - Health check at /health (already implemented in src/index.ts).
###############################################################################
option_settings:
  aws:elasticbeanstalk:container:nodejs:
    NodeCommand: "npm start"
    ProxyServer: none
  aws:elasticbeanstalk:application:
    Application Healthcheck URL: /health
  aws:elasticbeanstalk:environment:process:default:
    HealthCheckPath: /health
    HealthCheckInterval: 30
    HealthyThresholdCount: 2
    UnhealthyThresholdCount: 5
