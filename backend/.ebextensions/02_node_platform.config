###############################################################################
# Node platform settings.
#
# - On Amazon Linux 2023, the Procfile (web: npm start) is what tells EB how
#   to start the app — the legacy NodeCommand setting is no longer accepted.
# - ProxyServer must be one of [apache, nginx] on AL2023; "none" is rejected.
#   We keep the default nginx, and bump nginx's own proxy timeouts in
#   .platform/nginx/conf.d/01_proxy_timeout.conf so long Whisper/GPT requests
#   aren't killed at nginx's default 60-second proxy_read_timeout.
# - Health check at /health (already implemented in src/index.ts).
###############################################################################
option_settings:
  aws:elasticbeanstalk:application:
    Application Healthcheck URL: /health
  aws:elasticbeanstalk:environment:process:default:
    HealthCheckPath: /health
    HealthCheckInterval: 30
    HealthyThresholdCount: 2
    UnhealthyThresholdCount: 5
