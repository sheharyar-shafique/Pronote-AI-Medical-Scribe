# Copy this to .env.production and fill in the values BEFORE deploying to Amplify.
# Amplify also lets you set these in its console (Environment variables tab)
# — that is the recommended path so secrets never sit in git. This .example
# file is committed; the real .env.production is gitignored.

# URL of your Elastic Beanstalk backend. After EB deploy, paste in the
# EB-generated URL (e.g. https://pronote-prod.eba-xxxx.us-east-1.elasticbeanstalk.com/api)
# OR your custom domain (e.g. https://api.yourdomain.com/api).
# NOTE: include "/api" at the end — the backend mounts all routes under /api.
VITE_API_URL=https://CHANGE_ME.elasticbeanstalk.com/api

# Tells the frontend store to use the real backend (not mock data).
VITE_USE_API=true
